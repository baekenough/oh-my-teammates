{
  "name": "@oh-my-customcode/oh-my-teammates",
  "version": "0.4.2",
  "description": "Team collaboration addon for oh-my-customcode - organizational harness management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omcustom-team": "dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node && bun build cli.ts --outfile dist/cli.js --target node",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "node scripts/postinstall.js || true",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bunx biome check --write"
    ]
  },
  "peerDependencies": {
    "oh-my-customcode": ">=0.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.3",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oh-my-customcode": "^0.23.2"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "keywords": [
    "claude-code",
    "ai-agent",
    "team-collaboration",
    "harness",
    "oh-my-customcode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baekenough/oh-my-teammates.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
